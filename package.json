{
  "name": "roadtrip-blog",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write . --config ./.prettierrc --ignore-path ./.prettierignore",
    "format:check": "prettier --check . --config ./.prettierrc --ignore-path ./.prettierignore",
    "prepare": "husky",
    "test": "vitest run"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/speed-insights": "^1.3.1",
    "clsx": "^2.1.1",
    "contentlayer2": "^0.5.8",
    "github-slugger": "^2.0.0",
    "next": "^16.2.4",
    "next-contentlayer2": "^0.5.8",
    "next-themes": "^0.4.6",
    "postcss": "8.5.13",
    "react": "19.2.5",
    "react-calendar": "^6.0.1",
    "react-dom": "19.2.5",
    "react-simple-maps": "^3.0.0",
    "react-swipeable": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.11",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-simple-maps": "^3.0.6",
    "baseline-browser-mapping": "^2.10.24",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "vitest": "^4.0.17"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,md,mdx}": "prettier --write --config ./.prettierrc --ignore-path ./.prettierignore",
    "*.{ts,tsx,js,jsx}": "eslint",
    "*.{ts,js}": "vitest related --run --passWithNoTests"
  },
  "pnpm": {
    "overrides": {
      "d3-color": "3.1.0",
      "next-contentlayer>next": "$next",
      "react-simple-maps>react": "$react",
      "react-simple-maps>react-dom": "$react-dom",
      "react-swipeable>react": "$react",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}